# Local LLM endpoint — LM Studio (must be one of: http://localhost:1234/v1 or http://192.168.1.22:1234/v1)
LOCAL_LLM_BASE_URL=http://localhost:1234/v1
COMFYUI_BASE_URL=http://localhost:8188

# Local stack endpoints (Phase 0 normalized ports)
SEARXNG_BASE_URL=http://localhost:8080
ONYX_API_BASE_URL=http://localhost:3030/api
# Optional override for ingestion API (defaults to ONYX_API_BASE_URL with /api stripped)
# ONYX_INGESTION_BASE_URL=http://localhost:3030
# ONYX_API_KEY=replace-with-onyx-api-key-or-personal-access-token
ONYX_MCP_BASE_URL=http://localhost:8090/
# ONYX_MCP_AUTH_HEADER=Bearer replace-with-onyx-api-key-or-personal-access-token
# ONYX_MCP_PERSONA_HEADERS_JSON={"admin":"Bearer tokenA","member":"Bearer tokenB"}
# ONYX_MCP_EXPECT_ALLOW=admin
# ONYX_MCP_EXPECT_DENY=member

# Canonical local ports (used by scripts/docs)
LOCAL_PORT_CAPYBARA_UI=2026
LOCAL_PORT_CAPYBARA_GATEWAY=8001
LOCAL_PORT_CAPYBARA_LANGGRAPH=2024
LOCAL_PORT_SEARXNG=8080
LOCAL_PORT_ONYX=3030
LOCAL_PORT_CRAWL4AI=11235
LOCAL_PORT_COMFYUI=8188
LOCAL_PORT_ONYX_MCP=8090

# Optional one-command local stack management for ComfyUI
# COMFYUI_WORKDIR=/Users/yourname/Desktop/comfyUI
# COMFYUI_START_CMD=python3 main.py --listen 0.0.0.0 --port 8188

# Optional crawl4ai smoke-test tuning
# CRAWL4AI_SMOKE_URLS=https://docs.python.org/3/,https://github.com/onyx-dot-app/onyx
# CRAWL4AI_SMOKE_TIMEOUT_SECONDS=45
# CRAWL4AI_SMOKE_RETRIES=1
# CRAWL4AI_SMOKE_MIN_SUCCESS_RATE=0.67
# CORS Origins (comma-separated) - e.g., http://localhost:3000,http://localhost:3001
# CORS_ORIGINS=http://localhost:3000

# Optional gateway API key protection for /api/* endpoints
# CAPYBARA_API_KEY=replace-with-a-strong-random-value
# CAPYBARA_API_KEY_HEADER=x-api-key

# Optional:
# VOLCENGINE_API_KEY=your-volcengine-api-key
# OPENAI_API_KEY=your-openai-api-key
# GEMINI_API_KEY=your-gemini-api-key
# DEEPSEEK_API_KEY=your-deepseek-api-key
# NOVITA_API_KEY=your-novita-api-key  # OpenAI-compatible, see https://novita.ai
# SLACK_BOT_TOKEN=your-slack-bot-token
# SLACK_APP_TOKEN=your-slack-app-token
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
